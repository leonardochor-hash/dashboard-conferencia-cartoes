{
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "api/conferir.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/conferir",
      "dest": "/api/conferir.py"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ]
}
